Options -Indexes

RewriteEngine On

# Preserve the Authorization header for PHP (mod_php / PHP-FPM strip it
# otherwise — needed for the Bearer token on /api/*).
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^watch/([^/]+)/?$ watch.php?id=$1 [QSA,L,NC,B]
RewriteRule ^stream/([^/]+)/?$ stream.php?id=$1 [QSA,L,NC,B]
RewriteRule ^series/([^/]+)/?$ series.php?id=$1 [QSA,L,NC,B]
RewriteRule ^api(/.*)?$ api.php [QSA,L]

